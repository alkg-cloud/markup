generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("admin")
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model AgentToken {
  id          String    @id @default(cuid())
  name        String    @unique
  tokenHash   String    @unique
  prefix      String?
  lastFour    String?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
}

model Project {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  folders   Folder[]
  mockups   Mockup[]
}

model Folder {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mockups   Mockup[]

  @@unique([projectId, parentId, name])
  @@index([projectId])
  @@index([parentId])
}

model Mockup {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  status           String          @default("open")
  currentVersionId String?
  projectId        String?
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folderId         String?
  folder           Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  position         Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  versions         MockupVersion[]
  annotations      Annotation[]

  @@index([status])
  @@index([projectId])
  @@index([folderId])
}

model MockupVersion {
  id                   String       @id @default(cuid())
  mockupId             String
  mockup               Mockup       @relation(fields: [mockupId], references: [id], onDelete: Cascade)
  path                 String
  createdAt            DateTime     @default(now())
  createdBy            String
  createdByType        String
  annotationsCreatedOn Annotation[] @relation("CreatedOnVersion")
  @@index([mockupId])
}

model Annotation {
  id                 String         @id @default(cuid())
  mockupId           String
  mockup             Mockup         @relation(fields: [mockupId], references: [id], onDelete: Cascade)
  screenshotPath     String
  tldrawPath         String
  // Legacy pin coords (scroll/viewport/bbox JSON) — preserved for backfill;
  // dropped in Phase 13 after the anchors[] migration is verified.
  pinCoords          String?
  // AppMain redesign: array of Anchor objects (text-anchor or element-anchor),
  // shape per `docs/superpowers/specs/2026-05-18-pin-anchoring-strategy.md`.
  anchors            String         @default("[]")
  // Per-annotation color index (0..15) into the rotating palette. Shared
  // across all pins of this annotation, plus the rail badge and avatar.
  colorIndex         Int            @default(0)
  // Visual status surfaced as a pill in the rail header.
  status             String         @default("open") // "open" | "needs review" | "resolved"
  intentType         String         @default("other")
  createdOnVersionId String?
  createdOnVersion   MockupVersion? @relation("CreatedOnVersion", fields: [createdOnVersionId], references: [id])
  createdAt          DateTime       @default(now())
  createdBy          String
  createdByType      String
  thread             Thread?
  @@index([mockupId])
  @@index([createdOnVersionId])
}

model Thread {
  id           String     @id @default(cuid())
  annotationId String     @unique
  annotation   Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  status       String     @default("open")
  messages     Message[]
}

model Message {
  id         String     @id @default(cuid())
  threadId   String
  thread     Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorType String
  authorId   String
  body       String
  createdAt  DateTime   @default(now())
  reactions  Reaction[]
  @@index([threadId])
}

// Slack-style emoji reactions on individual comment messages. The
// (messageId, userId, emoji) tuple is unique — toggling a reaction is
// a delete-or-create operation.
model Reaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Config {
  key   String @id
  value String
}
