    "reset:tokens": "tsx scripts/reset-tokens.ts",
    "reset:all": "tsx scripts/reset-all.ts",
    "seed:dev": "node --conditions=react-server --env-file=.env --env-file=.env.local --import tsx scripts/seed-dev.ts",
    "landing:export": "pnpm --filter ./landing-export build"
