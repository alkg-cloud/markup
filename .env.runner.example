# Self-hosted runner bootstrap config — copy to .env.runner on the VPS
# and fill in real values. .env.runner is gitignored.

# Personal Access Token with `repo` scope. Used by myoung34/github-runner
# to fetch a fresh registration token on every start. v1 reuses the
# project's existing GITHUB_TOKEN.
ACCESS_TOKEN=

# Repo the runner registers against.
REPO_URL=https://github.com/alkg-cloud/markup

# Stable runner name shown in github.com/alkg-cloud/markup/settings/actions/runners.
RUNNER_NAME=markup-vps-1

# Labels — the deploy workflow selects on `self-hosted` + `markup-vps`.
RUNNER_LABELS=self-hosted,Linux,X64,markup-vps

# Ephemeral runners exit after one job. Combined with `restart: unless-stopped`
# in the compose file, the container re-registers a fresh runner per job.
EPHEMERAL=true
